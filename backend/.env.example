PORT=3000
CORS_ORIGIN=http://localhost:3001

# STORAGE_DRIVER selects where webhook requests are persisted: "sqlite" (default) or "redis"
STORAGE_DRIVER=sqlite

# Used when STORAGE_DRIVER=sqlite. Path to the SQLite database file.
SQLITE_PATH=./data/webhook-inspector.db

# Used when STORAGE_DRIVER=redis.
REDIS_URL=redis://redis:6379

